{
  "compilerOptions": {
    "module": "Node16",
    "lib": [
      "ES2018"
    ],
    "target": "ES2018",
    "moduleResolution": "node16",
    "outDir": "dist",
    "allowJs": true,
    "declaration": true,
    "strict": true,
    "noImplicitReturns": true,
    "allowSyntheticDefaultImports": true,
    "allowUnreachableCode": false,
    "skipLibCheck": true,
    "types": [
      "node",
      "mocha",
      "screeps"
    ]
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    "src/",
    "utils/",
    "test/",
  ]
}
